# First login (bootstrap superadmin — created once when no users exist)
SUPERADMIN_EMAIL=your-email@example.com
SUPERADMIN_PASSWORD=your-secure-password

# Legacy fallback if SUPERADMIN_PASSWORD is unset
ADMIN_PASSWORD=

# Set to 1 once to reset superadmin password from env, then remove
# SUPERADMIN_SYNC_PASSWORD=1

SECRET_KEY=change-me-to-a-long-random-value
PORT=5000

# Recommended on Railway: add a PostgreSQL service and reference its URL.
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# Optional: mount a Railway volume and point storage here for CSV + reports.
# DATA_DIR=/data/mw/data
# OUT_DIR=/data/mw/output

# First login (bootstrap superadmin — created once when no users exist)
SUPERADMIN_EMAIL=admin@misterwiz.local
SUPERADMIN_PASSWORD=change-me

# Legacy fallback if SUPERADMIN_PASSWORD is unset
ADMIN_PASSWORD=

SECRET_KEY=change-me-to-a-long-random-value
PORT=5000

